# Đăng ký free tại https://twelvedata.com → Dashboard → API Key
TWELVE_API_KEY=your_twelve_data_api_key_here

# Telegram Bot (lấy từ @BotFather)
TELEGRAM_TOKEN=123456789:ABCdefGHI...
TELEGRAM_CHAT_ID=123456789

# Tùy chỉnh (không bắt buộc)
CHECK_INTERVAL=300       # giây giữa mỗi lần kéo giá (mặc định 5 phút)
TOUCH_THRESHOLD=0.1      # % vùng "chạm" EMA (mặc định 0.1%)
